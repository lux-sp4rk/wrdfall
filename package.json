{
  "name": "word-loom",
  "version": "1.0.0",
  "private": true,
  "description": "wordfall - A calm, senior-first word puzzle game",
  "scripts": {
    "serve": "python3 -m http.server -d dist 8000",
    "open": "open http://localhost:8000",
    "minify": "node scripts/minify.js",
    "build:landing": "cd landing && npm run build",
    "build:all": "./build.sh",
    "deploy:prod": "npm run build:all && git add . && git commit -m 'Deploy web build' && git push origin main",
    "dev:landing": "cd landing && npm run dev",
    "build:godot": "./scripts/export-godot.sh",
    "sync": "./scripts/sync-repo.sh",
    "prepare": "./scripts/prepare.sh"
  },
  "workspaces": [
    "landing"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/lux-sp4rk/word-loom"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "html-minifier-terser": "^7.2.0",
    "lefthook": "^2.1.4",
    "terser": "^5.37.0"
  }
}
