#!/bin/bash

BRANCH=$(git rev-parse --abbrev-ref HEAD)
if [ "$BRANCH" = "main" ]; then
  echo "❌ Direct pushes to the main branch are not allowed. Please use a feature branch."
  exit 1
fi

echo "🔍 Checking if branch is up to date..."
git fetch origin main
LOCAL=$(git rev-parse HEAD)
REMOTE=$(git rev-parse origin/main)
BASE=$(git merge-base HEAD origin/main)

if [ "$LOCAL" = "$REMOTE" ]; then
    echo "✅ Already up to date."
elif [ "$LOCAL" = "$BASE" ]; then
    echo "❌ Your branch is behind origin/main. Run 'npm run sync' first."
    exit 1
fi

echo "🔨 Building Godot dist before push..."
npm run build:godot
if [ $? -ne 0 ]; then
  echo "❌ Godot build failed. Aborting push."
  exit 1
fi
echo "✅ Godot dist built successfully."
